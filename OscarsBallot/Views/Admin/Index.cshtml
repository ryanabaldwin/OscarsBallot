@model OscarsBallot.ViewModels.Admin.AdminWinnersViewModel
@{
    ViewData["Title"] = "Admin Winners";
}

<h1 class="mb-3">Admin Winners</h1>
<p class="text-muted">Select winners for categories and save. You can update one category at a time.</p>
<p>
    <a asp-action="Categories" class="btn btn-outline-secondary">Manage Categories</a>
</p>

<div class="card mb-3">
    <div class="card-body">
        <h5 class="card-title">Ballot Editing Control</h5>
        <p class="mb-2">
            Current status:
            <strong>@(Model.IsBallotEditingLocked ? "Locked" : "Open")</strong>
            @if (Model.BallotsLockedOverride.HasValue)
            {
                <span>(manual override)</span>
            }
            else
            {
                <span>(automatic cutoff at @Model.CeremonyStartMountain.ToString("h:mm tt, dddd MMM d, yyyy") MT)</span>
            }
        </p>
        <div class="d-flex flex-wrap gap-2">
            <form asp-action="SetBallotEditingMode" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="mode" value="lock" />
                <button type="submit" class="btn btn-outline-danger">Lock Ballots Now</button>
            </form>
            <form asp-action="SetBallotEditingMode" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="mode" value="unlock" />
                <button type="submit" class="btn btn-outline-success">Force Unlock</button>
            </form>
            <form asp-action="SetBallotEditingMode" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="mode" value="auto" />
                <button type="submit" class="btn btn-outline-secondary">Use Automatic Ceremony Cutoff</button>
            </form>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

@if (TempData["InfoMessage"] is string infoMessage)
{
    <div class="alert alert-info">@infoMessage</div>
}

<form asp-action="Index" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    @for (var i = 0; i < Model.Categories.Count; i++)
    {
        <div class="card mb-3">
            <div class="card-body">
                <input type="hidden" asp-for="Categories[i].CategoryId" />
                <h5 class="card-title mb-3">@Model.Categories[i].CategoryName</h5>

                <label asp-for="Categories[i].SelectedWinnerNomineeId" class="form-label">Winner</label>
                <select asp-for="Categories[i].SelectedWinnerNomineeId" class="form-select">
                    <option value="">Leave unset</option>
                    @foreach (var nominee in Model.Categories[i].Nominees)
                    {
                        <option value="@nominee.NomineeId">@nominee.Name</option>
                    }
                </select>
                <span asp-validation-for="Categories[i].SelectedWinnerNomineeId" class="text-danger"></span>
            </div>
        </div>
    }

    <button type="submit" class="btn btn-primary">Save Winner Updates</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
