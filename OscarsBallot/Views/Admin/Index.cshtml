@model OscarsBallot.ViewModels.Admin.AdminWinnersViewModel
@{
    ViewData["Title"] = "Admin Winners";
}

<h1 class="mb-3">Admin Winners</h1>
<p class="text-muted">Select winners for categories and save. You can update one category at a time.</p>
<p>
    <a asp-action="Categories" class="btn btn-outline-secondary">Manage Categories</a>
</p>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

@if (TempData["InfoMessage"] is string infoMessage)
{
    <div class="alert alert-info">@infoMessage</div>
}

<form asp-action="Index" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    @for (var i = 0; i < Model.Categories.Count; i++)
    {
        <div class="card mb-3">
            <div class="card-body">
                <input type="hidden" asp-for="Categories[i].CategoryId" />
                <h5 class="card-title mb-3">@Model.Categories[i].CategoryName</h5>

                <label asp-for="Categories[i].SelectedWinnerNomineeId" class="form-label">Winner</label>
                <select asp-for="Categories[i].SelectedWinnerNomineeId" class="form-select">
                    <option value="">Leave unset</option>
                    @foreach (var nominee in Model.Categories[i].Nominees)
                    {
                        <option value="@nominee.NomineeId">@nominee.Name</option>
                    }
                </select>
                <span asp-validation-for="Categories[i].SelectedWinnerNomineeId" class="text-danger"></span>
            </div>
        </div>
    }

    <button type="submit" class="btn btn-primary">Save Winner Updates</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
