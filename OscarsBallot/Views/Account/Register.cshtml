@model OscarsBallot.ViewModels.Account.RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
}

<h1 class="mb-3">Create Account</h1>
<p class="text-muted">Create an account to submit your Oscar ballot and track leaderboard results.</p>

<form asp-action="Register" method="post" class="mt-4">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="FirstName" class="form-label"></label>
        <input asp-for="FirstName" class="form-control"/>
        <span asp-validation-for="FirstName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="LastName" class="form-label"></label>
        <input asp-for="LastName" class="form-control"/>
        <span asp-validation-for="LastName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Pin" class="form-label"></label>
        <input asp-for="Pin" class="form-control" type="text" inputmode="numeric" pattern="[0-9]{4}" maxlength="4" />
        <span asp-validation-for="Pin" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ConfirmPin" class="form-label"></label>
        <input asp-for="ConfirmPin" class="form-control" type="text" inputmode="numeric" pattern="[0-9]{4}" maxlength="4" />
        <span asp-validation-for="ConfirmPin" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Create Account</button>
    <a asp-action="Login" class="btn btn-link">Already have an account? Sign in</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
