@model OscarsBallot.ViewModels.Account.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
}

<h1 class="mb-3">Sign In</h1>
<p class="text-muted">Sign in to submit or update your Oscar ballot.</p>

<form asp-action="Login" method="post" class="mt-4">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="FirstName" class="form-label"></label>
        <input asp-for="FirstName" class="form-control"/>
        <span asp-validation-for="FirstName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="LastName" class="form-label"></label>
        <input asp-for="LastName" class="form-control"/>
        <span asp-validation-for="LastName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Pin" class="form-label"></label>
        <input asp-for="Pin" class="form-control" type="text" inputmode="numeric" pattern="[0-9]{4}" maxlength="4" />
        <span asp-validation-for="Pin" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Sign In</button>
    <a asp-action="Register" class="btn btn-link">Need an account? Register</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
